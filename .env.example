# Token de acceso de la Graph API de Meta.
# Requisitos previos (una sola vez):
#   1. Cuenta en https://developers.facebook.com y una app (tipo "None"/"Other" basta).
#   2. Confirmación de identidad en https://www.facebook.com/ID — obligatoria para
#      consultar anuncios políticos vía API.
#   3. Genera un token de usuario en Graph API Explorer
#      (https://developers.facebook.com/tools/explorer/) y extiéndelo a 60 días en
#      https://developers.facebook.com/tools/debug/accesstoken/
META_ACCESS_TOKEN=pega_tu_token_aqui
